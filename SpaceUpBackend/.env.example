# ============================================
# SpaceUp Backend - Variables de Entorno
# ============================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA commitees el archivo .env ni credenciales reales.

# Entorno
NODE_ENV=development
PORT=3000

# Base de datos MySQL
DB_HOST=mysql
DB_PORT=3306
DB_USER=spaceup_user
DB_PASS=spaceup_password
DB_NAME=spaceup_db

# JWT Secret - genera uno seguro con:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TU_JWT_SECRET_SUPER_SEGURO_AQUI_MINIMO_64_CARACTERES_HEX

# Stripe (solo si se usan pagos reales)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_DEFAULT_CURRENCY=usd

# Almacenamiento local de archivos
UPLOAD_DIR=/app/uploads
PUBLIC_URL=http://localhost:3000

# APIs externas (opcional, para validación de DNI/RUC)
RENIEC_API_TOKEN=TU_TOKEN_AQULLOSQUE
SUNAT_API_TOKEN=TU_TOKEN_AQULLOSQUE

# CORS - dominios permitidos separados por comas
# En desarrollo puede ser "*"; en producción especifica dominios.
CORS_ORIGINS=http://localhost:4200,http://localhost:4000
